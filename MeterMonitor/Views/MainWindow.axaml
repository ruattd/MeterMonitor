<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MeterMonitor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="using:MeterMonitor.Views"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="850"
        x:Class="MeterMonitor.Views.MainWindow"
        Icon="/Assets/logo.ico" Title="Meter Monitor"
        Width="500" Height="850">
    <v:MainView>
        <v:MainView.DataContext>
            <vm:MainViewModel/>
        </v:MainView.DataContext>
    </v:MainView>
</Window>
